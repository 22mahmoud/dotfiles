#!/bin/sh

remote_sink=$(pamixer --list-sinks | grep "Starship" | awk '{print $1}')
local_sink=$(pamixer --list-sinks | grep "Built-in" | awk '{print $1}')
headphone_sink=$(pamixer --list-sinks | grep "WH-CH510" | awk '{print $1}')


c_sink=
if [ -n "$headphone_sink" ]; then
  c_sink="$headphone_sink"
elif [ -n "$remote_sink" ]; then
  c_sink="$remote_sink"
else
  c_sink="$local_sink"
fi

usage() {
  while IFS= read -r line; do
    printf '%s\n' "$line"
  done <<-EOF

  volume [ -i | -d | -t | -h ] 
    control volume with notifcations

  -h|help     show this help
  -i|inc      increase volume
  -d|dec      decrease volume
  -t|toggle   toggle volume mute/unmute
EOF
}

inc() {
  pamixer --sink "${c_sink}" -i 5
}

dec() {
  pamixer --sink "${c_sink}" -d 5
}

toggle() {
  pamixer --sink "${c_sink}" -t
}

get_icon() {
  volume=$(pamixer --sink "${c_sink}" --get-volume)

  if [ "$(pamixer --sink "${c_sink}" --get-mute)" = true ]; then
    icon=🔇
  elif [ "$volume" -gt 70 ]; then
    icon=🔊
  elif [ "$volume" -gt 30 ]; then
    icon=🔉
  elif [ "$volume" -gt 0 ]; then
    icon=🔈
  else
    icon=🔇
  fi

  echo $icon
}

notify() {
  notify-send \
    -t 1500 \
    -u low \
    "$(get_icon) Sound" "Volume: $(pamixer --sink "${c_sink}" --get-volume-human)" \
    -h string:x-canonical-private-synchronous:"changeVolume"

}

main() {
  case "$1" in
    -h | help) usage ;;
    -i | inc) inc ;;
    -d | dec) dec ;;
    -t | toggle) toggle ;;
    *) exit 0 ;;
  esac

  notify
}

main "$@"
